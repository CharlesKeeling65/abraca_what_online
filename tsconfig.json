{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "outDir": "dist",
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "scripts/**/*.ts"
  ]
}
